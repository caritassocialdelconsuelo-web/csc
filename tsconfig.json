{
  "extends": "./.quasar/tsconfig.json",
  "compilerOptions": {
    "target": "ES6",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true // Opcional: solo si necesitas reflexión de tipos
  },
  "exclude": [
    "node_modules",
    "ignore-folder/*", // Excluye la carpeta completa
    "ignore-folder/**/*", // Excluye la carpeta completa
    "ignore-folder", // Excluye la carpeta completa
    "prompts",
    "src/componentes/archivo_ignorar.ts" // Excluye un archivo específico
  ]
}
